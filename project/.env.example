# ──────────────────────────────────────────────────────────────────────────────
# Jaithra Lab – Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (public – safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://fwgnlxfbuboudhowzglk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (SERVER ONLY – never expose to browser)
# Find at: https://supabase.com/dashboard/project/fwgnlxfbuboudhowzglk/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret for admin session cookies (any random string, min 32 chars)
JWT_SECRET=jaithra-lab-admin-jwt-secret-2026-pranav-secure-key

# Email notifications via Resend (free at https://resend.com)
# Sign up → Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key_here

# Admin email that receives booking notifications
NEXT_PUBLIC_ADMIN_EMAIL=pranavkothakunta@gmail.com
